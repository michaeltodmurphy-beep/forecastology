KALSHI_API_KEY=your-api-key-here
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
MYSQL_DATABASE_URL=******localhost:3306/forecastology
TRADING_MODE=PAPER
INITIAL_CONTRACT_COUNT=1
MONITOR_START_PRICE=0.80
BUY_TRIGGER_PRICE=0.85
SPREAD_MONITOR_PRICE=0.90
MINIMUM_SPREAD=0.07
HEDGE_TRIGGER_PRICE=0.50
# When a held bracket weakens to HEDGE_TRIGGER_PRICE and no sibling has an ask
# >= HEDGE_TRIGGER_PRICE yet (all weak), the event is armed and a recovery bracket
# is bought only once a sibling's YES ask rises STRICTLY ABOVE this value (HEDGE_BUY).
# i.e.: normal hedge fires immediately when best sibling >= HEDGE_TRIGGER_PRICE;
# deferred/recovery hedge fires only when a sibling > HEDGE_BUY after arming.
HEDGE_BUY=0.60
STOP_LOSS_PRICE=0.25
ENABLE_FAST_SL_EXIT=true
SL_EXIT_MODE=PANIC_FLATTEN
SL_EXIT_RETRY_INTERVAL_MS=300
SL_EXIT_MAX_ATTEMPTS=3
SL_EXIT_AGGRESSIVE_OFFSET_TICKS=2
SL_EXIT_MAX_SLIPPAGE=0.20
# Maximum seconds to hold an AGGRESSIVE_LIMIT stop-loss trigger when spread is
# wide/one-sided before forcing exit anyway. PANIC_FLATTEN still fires
# immediately once yes_ask <= STOP_LOSS_PRICE. Set 0 to disable holding.
SL_SPREAD_HOLD_MAX_SECONDS=120
# PANIC_FLATTEN settings (used when SL_EXIT_MODE=PANIC_FLATTEN)
# SL_PANIC_SELL_PRICE: floor price in cents — a sell at 1¢ is immediately
# marketable and Kalshi matches it at the best available bid.
SL_PANIC_SELL_PRICE=1
SL_PANIC_RETRY_MS=250
SL_PANIC_MAX_RETRIES=5
# Max age (ms) of a cached YES ask quote before it is considered stale for
# PANIC_FLATTEN pre-submit revalidation. Set to 0 to disable. Default: 30000.
# SL_PANIC_MAX_QUOTE_AGE_MS=30000
HEDGE_MAX_FACTOR=5
# Brackets priced at or below this (cents, dollar format ok) are skipped in the
# watchlist evaluation and not logged as below_trigger. Data still streams for hedging.
EVAL_PRICE_FLOOR=0.05
REST_BASE_URL=https://external-api.kalshi.com
WS_URL=wss://external-api-ws.kalshi.com/trade-api/ws/v2
WEATHER_SERIES_PREFIX=KXWEATHER
# Trade-direction toggles — set to 'no' to disable new entry placement for
# the corresponding city-temperature family.  Existing open positions are
# always fully managed (SL / exit) regardless of these flags.
# Default: yes (both enabled).
LOW_TRADES=yes
HIGH_TRADES=yes
# Ownership safety switch:
# false (default): only APP-owned qty is managed by stop-loss/exit logic.
# true: legacy behavior, allows managing aggregate positions (including manual/external).
MANAGE_EXTERNAL_POSITIONS=false
# City-local-time entry settle gate.
# Prevents new buys before the city's own clock reaches the threshold.
# Kalshi settles temperature markets overnight; entries before rollover
# would target the prior settlement day.
# ENABLE_LOCAL_SETTLE_GATE=true   # true/false  (default: true)
# DEFAULT_ENTRY_START_LOCAL=01:00 # HH:MM; applies to all cities except Phoenix
# PHOENIX_ENTRY_START_LOCAL=00:00 # HH:MM; Phoenix stays on MST year-round (no DST)
