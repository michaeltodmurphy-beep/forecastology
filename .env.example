KALSHI_API_KEY=your-api-key-here
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
MYSQL_DATABASE_URL=******localhost:3306/forecastology
TRADING_MODE=PAPER
INITIAL_CONTRACT_COUNT=1
MONITOR_START_PRICE=0.80
BUY_TRIGGER_PRICE=0.85
SPREAD_MONITOR_PRICE=0.90
MINIMUM_SPREAD=0.07
HEDGE_TRIGGER_PRICE=0.50
# When a held bracket weakens to HEDGE_TRIGGER_PRICE and no sibling has an ask
# >= HEDGE_TRIGGER_PRICE yet (all weak), the event is armed and a recovery bracket
# is bought only once a sibling's YES ask rises STRICTLY ABOVE this value (HEDGE_BUY).
# i.e.: normal hedge fires immediately when best sibling >= HEDGE_TRIGGER_PRICE;
# deferred/recovery hedge fires only when a sibling > HEDGE_BUY after arming.
HEDGE_BUY=0.60
STOP_LOSS_PRICE=0.25
HEDGE_MAX_FACTOR=5
# Brackets priced at or below this (cents, dollar format ok) are skipped in the
# watchlist evaluation and not logged as below_trigger. Data still streams for hedging.
EVAL_PRICE_FLOOR=0.05
REST_BASE_URL=https://external-api.kalshi.com
WS_URL=wss://external-api-ws.kalshi.com/trade-api/ws/v2
WEATHER_SERIES_PREFIX=KXWEATHER
